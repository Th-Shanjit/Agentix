# Vercel Postgres — paste from Vercel project → Storage → .env.local snippet
POSTGRES_PRISMA_URL="postgres://..."
POSTGRES_URL_NON_POOLING="postgres://..."

# NextAuth / Auth.js — generate secret: `openssl rand -base64 32`
AUTH_SECRET=""
# Optional; Vercel sets automatically. Local: http://localhost:3000
# AUTH_URL="http://localhost:3000"

# Google OAuth (recommended for local dev)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email magic link (optional) — e.g. Resend SMTP or other EMAIL_SERVER string for Nodemailer
# EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
# EMAIL_FROM="Agentix <onboarding@example.com>"

# Google AI (Gemini) — server-side only; never expose to the client bundle
GEMINI_API_KEY=""

# GitHub Actions → POST /api/webhooks/cron-scraper
# Send header: x-agentix-secret: <same value>  OR  Authorization: Bearer <same>
CRON_WEBHOOK_SECRET=""
