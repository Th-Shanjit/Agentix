# Vercel Postgres — pooled connection string (required for the app + Prisma)
# From Vercel → Storage → Postgres → copy the `POSTGRES_PRISMA_URL` value.
POSTGRES_PRISMA_URL="postgres://..."
#
# Prisma CLI (`npx prisma db push`) only auto-loads `.env`, NOT `.env.local`.
# Use either:
#   - `npm run db:push` (loads `.env.local` via dotenv-cli), or
#   - duplicate `POSTGRES_PRISMA_URL` into a root `.env` file for raw `npx prisma` commands.

# NextAuth / Auth.js — required. Generate: `openssl rand -base64 32`
# (Some setups use NEXTAUTH_SECRET instead; either works.)
AUTH_SECRET=""
# NEXTAUTH_SECRET=""
# Required in production: full site URL, no trailing slash (matches browser origin).
# Local: http://localhost:3000
# Vercel: https://your-app.vercel.app  (or your custom domain)
AUTH_URL="http://localhost:3000"

# Google OAuth — create an OAuth client (Web) in Google Cloud Console → APIs & Services → Credentials.
# Authorized JavaScript origins: http://localhost:3000
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email magic link (optional) — e.g. Resend SMTP or other EMAIL_SERVER string for Nodemailer
# EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
# EMAIL_FROM="Agentix <onboarding@example.com>"

# Google AI (Gemini) — server-side only; never expose to the client bundle
GEMINI_API_KEY=""

# GitHub Actions → POST /api/webhooks/cron-scraper
# Send header: x-agentix-secret: <same value>  OR  Authorization: Bearer <same>
CRON_WEBHOOK_SECRET=""
