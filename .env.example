# Vercel Postgres — pooled connection string (required for the app + Prisma)
# From Vercel → Storage → Postgres → copy the `POSTGRES_PRISMA_URL` value.
POSTGRES_PRISMA_URL="postgres://..."
#
# Prisma CLI (`npx prisma db push`) only auto-loads `.env`, NOT `.env.local`.
# Use either:
#   - `npm run db:push` (loads `.env.local` via dotenv-cli), or
#   - duplicate `POSTGRES_PRISMA_URL` into a root `.env` file for raw `npx prisma` commands.

# NextAuth / Auth.js — required. Generate: `openssl rand -base64 32`
# (Some setups use NEXTAUTH_SECRET instead; either works.)
# REQUIRED on Vercel Production: if missing or empty, Google sign-in returns HTTP 500
# "There is a problem with the server configuration" (Auth.js MissingSecret).
AUTH_SECRET=""
# NEXTAUTH_SECRET=""
# Required in production: full site URL, no trailing slash (matches browser origin).
# Local: http://localhost:3000
# Vercel: https://your-app.vercel.app  (or your custom domain)
AUTH_URL="http://localhost:3000"
# Optional: set to true in Vercel to see detailed Auth.js logs for one deploy, then remove.
# AUTH_DEBUG="true"

# Google OAuth — create an OAuth client (Web) in Google Cloud Console → APIs & Services → Credentials.
# Authorized JavaScript origins: http://localhost:3000 (and your production origin, e.g. https://your-app.vercel.app)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google (and production: https://your-app.vercel.app/api/auth/callback/google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Same values; supported for hosts that only expose Auth.js-style names:
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_GOOGLE_CLIENT_ID=""
# AUTH_GOOGLE_CLIENT_SECRET=""

# Vercel production checklist (same names as local; scope to “Production”):
# - AUTH_SECRET (non-empty) — without this, /api/auth/* returns 500 Configuration on sign-in
# - AUTH_URL — https://your-deployment.vercel.app (no trailing slash)
# - POSTGRES_PRISMA_URL — database (OAuth callback creates/links User via Prisma)
# - GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET — Google OAuth
# Then redeploy. Missing GOOGLE_* causes “No auth providers” on /login; missing AUTH_SECRET
# causes “server configuration” error after clicking Continue with Google.

# Email magic link (optional) — e.g. Resend SMTP or other EMAIL_SERVER string for Nodemailer
# EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
# EMAIL_FROM="Agentix <onboarding@example.com>"

# Google AI (Gemini) — server-side only; never expose to the client bundle
GEMINI_API_KEY=""

# GitHub Actions → POST /api/webhooks/cron-scraper, /api/webhooks/ingest-jobs,
# and /api/webhooks/alerts-digest
# Send header: x-agentix-secret: <same value>  OR  Authorization: Bearer <same>
CRON_WEBHOOK_SECRET=""

# JSearch via RapidAPI — populates the shared job catalog (POST /api/webhooks/ingest-jobs)
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=""
# Optional override (default: jsearch.p.rapidapi.com)
# JSEARCH_RAPIDAPI_HOST="jsearch.p.rapidapi.com"

# Default search query when ingest body omits "query"
# DEFAULT_INGEST_QUERY="software engineer remote"
