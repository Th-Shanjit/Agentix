// Agentix — Vercel Postgres (Neon). RLS simulation: always scope queries by `userId` in app code.
// Auth.js tables follow https://authjs.dev/reference/adapter/prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

enum RemotePreference {
  ANY
  REMOTE_ONLY
  HYBRID
  ONSITE
}

enum CtcSource {
  API
  INFERRED
  MANUAL
}

enum IngestionStatus {
  VALIDATED
  REJECTED
}

enum AlertDigestFrequency {
  DAILY
}

model User {
  id                     String            @id @default(cuid())
  name                   String?
  email                  String?           @unique
  passwordHash           String?
  emailVerified          DateTime?
  image                  String?
  resumeText             String?           @db.Text
  bragSheet              String?           @db.Text
  yearsExperience        Int?
  preferredCountries     Json?
  preferredRoles         Json?
  searchRemotePreference RemotePreference? @default(ANY)
  alertEmailsEnabled     Boolean           @default(true)
  alertDigestFrequency   AlertDigestFrequency @default(DAILY)
  lastAlertDigestAt      DateTime?
  createdAt              DateTime          @default(now())
  accounts               Account[]
  sessions               Session[]
  userJobs               UserJob[]
  trackers               Tracker[]
  matchCaches            JobMatchCache[]
  alertEvents            AlertEvent[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Shared job posting (global catalog). Per-user state lives on `UserJob`.
model JobListing {
  id                   String          @id @default(cuid())
  title                String
  archetype            String?
  company              String
  location             String?
  sourceUrl            String          @unique
  dedupeKey            String          @unique
  ctc                  String?
  ctcSource            CtcSource       @default(MANUAL)
  salaryMin            Int?
  salaryMax            Int?
  salaryCurrency       String?         @default("USD")
  source               String
  sourceName           String?
  externalId           String?
  description          String?         @db.Text
  employmentType       String?
  remotePolicy         String?
  countryCodes         Json?
  experienceYearsMin   Int?
  experienceYearsMax   Int?
  careersUrl           String?
  archivedAt           DateTime?
  postedAt             DateTime        @default(now())
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  ingestionStatus    IngestionStatus @default(VALIDATED)
  rejectionReason      String?
  rawPayload           Json?

  userJobs     UserJob[]
  matchCaches  JobMatchCache[]
  enrichment   JobEnrichment?
  alertEvents  AlertEvent[]

  @@index([postedAt])
  @@index([company])
  @@index([title])
}

model UserJob {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobListingId String
  jobListing   JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  applied      Boolean  @default(false)
  appliedAt    DateTime?
  saved        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, jobListingId])
  @@index([userId])
}

/// Cached AI match scores for search (per user + listing).
model JobMatchCache {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobListingId   String
  jobListing     JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  relevanceScore Float
  fitScore       Float
  upsideScore    Float
  strengths      Json
  weaknesses     Json
  updatedAt      DateTime @updatedAt

  @@unique([userId, jobListingId])
  @@index([userId])
}

/// Cached enrichment for job detail (ratings summary, CTC bands, resume analysis).
model JobEnrichment {
  id             String     @id @default(cuid())
  jobListingId   String     @unique
  jobListing     JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  ctcBands       Json?
  ratingsWeb     Json?
  forumSentiment Json?
  resumeAnalysis Json?
  fiveToneResumes Json?
  interviewStories Json?
  negotiationStrategy Json?
  updatedAt      DateTime   @updatedAt
}

model Tracker {
  id      String  @id @default(cuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company String
  url     String
  active  Boolean @default(true)
  alertEvents AlertEvent[]

  @@index([userId])
  @@index([company])
}

model AlertEvent {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobListingId  String
  jobListing    JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  trackerId     String?
  tracker       Tracker? @relation(fields: [trackerId], references: [id], onDelete: SetNull)
  matchedRole   String?
  sentAt        DateTime?
  createdAt     DateTime @default(now())

  @@unique([userId, jobListingId])
  @@index([userId, sentAt])
  @@index([createdAt])
}
